ADMIN_SETUP_KEY=

# Owner / super admin.
# The email set here is granted super-admin (owner) powers when its account is
# created or reset via the admin setup/reset flow. The super admin is the only
# role that can invite/remove other admins. Fill this in with the owner's email,
# then run the admin setup (or admin reset) for that email.
# If left blank, the FIRST account created through the setup flow becomes the owner.
SUPER_ADMIN_EMAIL=

# Public base URL, used to build links in emails (e.g. admin invite links).
# Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_BASE_URL=

# SMTP Configuration (order confirmation emails)
# If not set, emails are sent via Ethereal test accounts (dev only – not delivered to real recipients)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=PrintersRUs <orders@printersrus.co.uk>

# Payment Providers
STRIPE_SECRET_KEY=
